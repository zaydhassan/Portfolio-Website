# Contact form — email delivery via Gmail SMTP (Nodemailer).
# Copy this file to `.env.local` and fill in the values.

# The inbox that receives contact messages (defaults to zaydthirteen@gmail.com).
CONTACT_TO_EMAIL=zaydthirteen@gmail.com

# A Gmail account that SENDS the messages. Use an App Password, NOT your
# real password. Steps:
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Paste the 16-char password below (no spaces).
GMAIL_USER=zaydthirteen@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Digital twin — AI chat assistant (Google Gemini).
# Powers the conversational assistant in the Contact section.
# Without a key, the assistant falls back to local keyword-based answers
# from your data, so it still works out-of-the-box.
#
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: override the model (defaults to gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash